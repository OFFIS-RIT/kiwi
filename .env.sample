# App
LOG_LEVEL=info
APP_DOMAIN=localhost
# TLS_EMAIL=ops@example.com
MASTER_USER_ID=<user_id>
MASTER_USER_NAME=Master User
MASTER_USER_EMAIL=
MASTER_USER_PASSWORD=
# MASTER_USER_API_BYPASS=<long_random_api_token>

# Frontend (local bun dev)
NEXT_PUBLIC_API_URL=http://localhost:4321
NEXT_PUBLIC_AUTH_URL=http://localhost:4321/auth
# Change to "credentials" for internal auth or "ldap" for LDAP auth
NEXT_PUBLIC_AUTH_MODE=credentials
NEXT_PUBLIC_APP_BUILD_LABEL=

# Production frontend image defaults to /api and /auth.
# Override these only when building a custom image.
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_AUTH_URL=/auth

# Database
# Host values are used by local bun processes.
DATABASE_URL=postgresql://kiwi:kiwi@localhost:5432/kiwi?sslmode=disable
DATABASE_DIRECT_URL=postgresql://kiwi:kiwi@localhost:5433/kiwi?sslmode=disable

# Auth
AUTH_SECRET=<random_secret_min_32_chars>
AUTH_URL=http://localhost:4321/auth
# AUTH_URL=https://yourdomain.com/auth -- For production
# TRUSTED_ORIGINS=https://app.example.com,https://admin.example.com
# AUTH_CROSS_SUBDOMAIN_COOKIES=true
# AUTH_COOKIE_DOMAIN=.example.com
WORKER_CONCURRENCY=1

# When frontend and backend are served behind one Caddy host, keep the frontend
# on relative paths and trust that public origin here instead.
# Example:
# TRUSTED_ORIGINS=https://kiwi.example.com
# NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_AUTH_URL=/auth

# Auth options
# APPLE_CLIENT_ID=<apple_client_id>
# APPLE_CLIENT_SECRET=<apple_client_secret>
# APPLE_BUNDLE_ID=<apple_bundle_id>
# GOOGLE_CLIENT_ID=<google_client_id>
# GOOGLE_CLIENT_SECRET=<google_client_secret>
# MICROSOFT_CLIENT_ID=<microsoft_client_id>
# MICROSOFT_CLIENT_SECRET=<microsoft_client_secret>
# MICROSOFT_TENANT_ID=<microsoft_tenant_id>
# MICROSOFT_AUTHORITY_URL=https://login.microsoftonline.com/common

# LDAP -- disables email and password login when enabled
# LDAP_URL=ldaps://ldap.example.com:636
# LDAP_BIND_DN=cn=readonly,dc=example,dc=com
# LDAP_PASSW=<ldap_password>
# LDAP_BASE_DN=dc=example,dc=com
# LDAP_SEARCH_ATTR=uid

# S3 / RustFS
S3_REGION=eu-central-1
S3_ENDPOINT=http://localhost:9000
# APP_DOMAIN=kiwi.example.com -- For production with Caddy
S3_ACCESS_KEY_ID=kiwi
S3_SECRET_ACCESS_KEY=kiwi
S3_BUCKET=kiwi

# AI
# Supported adapters: openai, azure, anthropic, openaiAPI
# Use openaiAPI for Ollama, OpenRouter, vLLM, llama.cpp, and similar OpenAI-compatible APIs.

# Text / chat
AI_TEXT_ADAPTER=openai
AI_TEXT_MODEL=gpt-5.2
AI_TEXT_KEY=<api_key>
# AI_TEXT_URL=http://localhost:11434/v1
# AI_TEXT_RESOURCE_NAME=<azure_resource_name>

# Embeddings
AI_EMBEDDING_ADAPTER=openai
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_KEY=<api_key>
# AI_EMBEDDING_URL=http://localhost:11434/v1
# AI_EMBEDDING_RESOURCE_NAME=<azure_resource_name>
AI_EMBED_DIM=1536

# Optional image / vision model
# AI_IMAGE_ADAPTER=openai
# AI_IMAGE_MODEL=gpt-4.1-mini
# AI_IMAGE_KEY=<api_key>
# AI_IMAGE_URL=https://api.openai.com/v1
# AI_IMAGE_RESOURCE_NAME=<azure_resource_name>

# Optional audio model
# AI_AUDIO_ADAPTER=openai
# AI_AUDIO_MODEL=gpt-4o-mini-transcribe
# AI_AUDIO_KEY=<api_key>
# AI_AUDIO_URL=https://api.openai.com/v1
# AI_AUDIO_RESOURCE_NAME=<azure_resource_name>

# Optional OpenTelemetry export for the API logs
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/logs
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://localhost:4318/v1/logs
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# Worker-local AI request concurrency per capability
AI_TEXT_CONCURRENCY=64
AI_IMAGE_CONCURRENCY=64
AI_EMBEDDING_CONCURRENCY=64
AI_AUDIO_CONCURRENCY=64
