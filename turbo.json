{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "globalDependencies": [".env"],
    "globalPassThroughEnv": [
        "LOG_LEVEL",
        "APP_DOMAIN",
        "MASTER_USER_ID",
        "MASTER_USER_NAME",
        "MASTER_USER_EMAIL",
        "MASTER_USER_PASSWORD",
        "API_URL",
        "BUILD_LABEL",
        "INTERNAL_AUTH_URL",
        "DATABASE_URL",
        "DATABASE_DIRECT_URL",
        "AUTH_SECRET",
        "AUTH_URL",
        "TRUSTED_ORIGINS",
        "AUTH_CROSS_SUBDOMAIN_COOKIES",
        "AUTH_COOKIE_DOMAIN",
        "DOCUMENT_MODE",
        "WORKER_CONCURRENCY",
        "AI_TEXT_CONCURRENCY",
        "AI_IMAGE_CONCURRENCY",
        "AI_EMBEDDING_CONCURRENCY",
        "AI_AUDIO_CONCURRENCY",
        "AI_VIDEO_CONCURRENCY",
        "LDAP_URL_CONFIGURED",
        "LDAP_BIND_DN_CONFIGURED",
        "LDAP_PASSW_CONFIGURED",
        "LDAP_BASE_DN_CONFIGURED",
        "LDAP_SEARCH_ATTR_CONFIGURED",
        "APPLE_CLIENT_ID",
        "APPLE_CLIENT_SECRET",
        "APPLE_BUNDLE_ID",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "MICROSOFT_CLIENT_ID",
        "MICROSOFT_CLIENT_SECRET",
        "MICROSOFT_TENANT_ID",
        "MICROSOFT_AUTHORITY_URL",
        "LDAP_URL",
        "LDAP_BIND_DN",
        "LDAP_PASSW",
        "LDAP_BASE_DN",
        "LDAP_SEARCH_ATTR",
        "S3_REGION",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET",
        "CONTEXT_WINDOW",
        "OTEL_EXPORTER_OTLP_ENDPOINT",
        "OTEL_EXPORTER_OTLP_LOGS_ENDPOINT",
        "OTEL_EXPORTER_OTLP_HEADERS"
    ],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "out/**", "dist/**"]
        },
        "test": {
            "dependsOn": ["^test"],
            "outputs": []
        },
        "dev": {
            "persistent": true,
            "cache": false
        }
    }
}
