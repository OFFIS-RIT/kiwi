{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "globalDependencies": [".env"],
    "globalPassThroughEnv": ["DATABASE_URL"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": [".next/**", "!.next/cache/**", "out/**", "dist/**"]
        },
        "dev": {
            "persistent": true,
            "cache": false
        }
    }
}
