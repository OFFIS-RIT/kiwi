{
    "name": "kiwi",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "dotenv -- turbo build",
        "dev": "dotenv -- turbo dev",
        "test": "dotenv -- turbo test",
        "lint": "oxlint",
        "format": "oxfmt",
        "worker:dash": "dotenv -- bun run --filter @kiwi/worker dashboard",
        "db:generate": "dotenv -- drizzle-kit generate",
        "db:migrate": "dotenv -- drizzle-kit migrate",
        "db:studio": "dotenv -- drizzle-kit studio"
    },
    "dependencies": {
        "drizzle-orm": "catalog:"
    },
    "devDependencies": {
        "@types/bun": "catalog:",
        "dotenv-cli": "^11.0.0",
        "drizzle-kit": "^1.0.0-rc.2",
        "oxfmt": "^0.48.0",
        "oxlint": "^1.63.0",
        "turbo": "^2.9.12"
    },
    "overrides": {
        "zod": "4.4.3"
    },
    "packageManager": "bun@1.3.11",
    "catalog": {
        "drizzle-orm": "1.0.0-rc.1",
        "@t3-oss/env-core": "^0.13.11",
        "openworkflow": "^0.9.0",
        "postgres": "^3.4.9",
        "better-result": "^2.9.2",
        "@types/bun": "1.3.13",
        "typescript": "^6.0.3",
        "better-auth": "1.6.10",
        "@better-auth/api-key": "1.6.10",
        "better-auth-credentials-plugin": "0.5.2",
        "pg": "^8.20.0",
        "@types/pg": "^8.18.0",
        "bun-types": "latest",
        "zod": "4.4.3",
        "next": "^16.2.6",
        "next-themes": "^0.4.6",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "@types/node": "^25.6.2",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@ai-sdk/anthropic": "^3.0.76",
        "@ai-sdk/azure": "^3.0.64",
        "@ai-sdk/openai": "^3.0.63",
        "@ai-sdk/openai-compatible": "^2.0.47",
        "@ai-sdk/provider": "^3.0.10",
        "@ai-sdk/react": "^3.0.179",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ai": "^6.0.177"
    },
    "patchedDependencies": {
        "openworkflow@0.9.0": "patches/openworkflow@0.9.0.patch"
    }
}
