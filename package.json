        "oxlint": "^1.56.0",
        "turbo": "^2.9.4"
    },
    "packageManager": "bun@1.3.11",
    "catalog": {
        "@t3-oss/env-core": "^0.13.11",
        "openworkflow": "^0.8.1",
        "postgres": "^3.4.8",
        "drizzle-orm": "^1.0.0-beta.19",
        "better-result": "^2.8.1",
        "@types/bun": "latest",
        "typescript": "^5",
        "better-auth": "^1.5.5",
        "better-auth-credentials-plugin": "0.5.2",
        "pg": "^8.20.0",
        "@types/pg": "^8.18.0",
