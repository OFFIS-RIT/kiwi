{
    "name": "kiwi",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "build": "dotenv -- turbo build",
        "dev": "dotenv -- turbo dev",
        "test": "dotenv -- turbo test",
        "lint": "oxlint",
        "format": "oxfmt",
        "tree-sitter:repair": "bun scripts/repair-tree-sitter-bindings.ts",
        "tree-sitter:rebuild": "bun scripts/repair-tree-sitter-bindings.ts --rebuild",
        "postinstall": "bun run tree-sitter:rebuild",
        "worker:dash": "dotenv -- bun run --filter @kiwi/worker dashboard",
        "db:generate": "dotenv -- drizzle-kit generate",
        "db:migrate": "dotenv -- drizzle-kit migrate",
        "db:studio": "dotenv -- drizzle-kit studio"
    },
    "dependencies": {
        "force": "^0.0.3"
    },
    "devDependencies": {
        "@types/bun": "catalog:",
        "dotenv-cli": "^11.0.0",
        "drizzle-kit": "catalog:",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.70.0",
        "oxlint-tsgolint": "^0.23.0",
        "turbo": "^2.9.18"
    },
    "overrides": {
        "prosemirror-model": "1.25.7",
        "zod": "4.4.3"
    },
    "packageManager": "bun@1.3.11",
    "catalog": {
        "drizzle-orm": "1.0.0-rc.3",
        "drizzle-kit": "1.0.0-rc.3",
        "effect": "^4.0.0-beta.83",
        "@effect/sql-pg": "^4.0.0-beta.83",
        "pg": "^8.22.0",
        "@types/pg": "^8.18.0",
        "@t3-oss/env-core": "^0.13.11",
        "openworkflow": "^0.9.0",
        "postgres": "^3.4.9",
        "@types/bun": "1.3.14",
        "typescript": "^6.0.3",
        "better-auth": "1.6.19",
        "@better-auth/api-key": "1.6.19",
        "better-auth-credentials-plugin": "0.5.2",
        "bun-types": "latest",
        "zod": "4.4.3",
        "next": "^16.2.9",
        "next-themes": "^0.4.6",
        "react": "^19.2.7",
        "react-dom": "^19.2.7",
        "@types/node": "^25.9.4",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19",
        "@ai-sdk/anthropic": "^4.0.0",
        "@ai-sdk/azure": "^4.0.1",
        "@ai-sdk/openai": "^4.0.1",
        "@ai-sdk/openai-compatible": "^3.0.0",
        "@ai-sdk/provider": "^4.0.0",
        "@ai-sdk/react": "^4.0.4",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "ai": "^7.0.3"
    },
    "patchedDependencies": {
        "openworkflow@0.9.0": "patches/openworkflow@0.9.0.patch"
    },
    "trustedDependencies": [
        "@tree-sitter-grammars/tree-sitter-zig",
        "@tree-sitter-grammars/tree-sitter-kotlin",
        "tree-sitter",
        "tree-sitter-bash",
        "tree-sitter-c",
        "tree-sitter-c-sharp",
        "tree-sitter-cpp",
        "tree-sitter-javascript",
        "tree-sitter-java",
        "tree-sitter-go",
        "tree-sitter-rust",
        "tree-sitter-php",
        "tree-sitter-python",
        "tree-sitter-typescript"
    ]
}
