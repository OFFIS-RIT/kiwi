{
	auto_https disable_redirects
}

(app) {
	request_body {
		max_size 4GB
	}

	@next_static path /_next/static/*
	handle @next_static {
		header Cache-Control "public, immutable"
		reverse_proxy frontend:3000
	}

	@auth path /auth /auth/*
	handle @auth {
		reverse_proxy server:4321
	}

	@api path /api /api/*
	handle @api {
		uri strip_prefix /api
		reverse_proxy server:4321 {
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000
	}
}

{$APP_DOMAIN:localhost} {
	tls {$TLS_EMAIL}

	import app
}
